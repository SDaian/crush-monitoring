{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Health endpoint response",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "version", "uptime"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["ok", "degraded", "down"]
    },
    "version": {
      "type": "string"
    },
    "uptime": {
      "type": "number"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  }
}
