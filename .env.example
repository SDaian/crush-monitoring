# Copy this file to `.env` and fill in values. `.env` is gitignored — NEVER
# commit real secrets, tokens, or passwords to the repository.
#
# The ticket watcher (scripts/ticket-watch.js) reads these. All are optional:
# with none set, the watcher still works and prints results to the console.

# --- Ticket watcher ---------------------------------------------------------

# Public page to watch. Defaults to the FWC26 shop seat-selection URL if unset.
# TICKET_URL=https://fwc26-shop-usd.tickets.fifa.com/secure/selection/event/seat/performance/10229226725341/table/1/lang/es

# Optional CSS selector to narrow what is hashed (reduces false "changed"
# notifications from unrelated dynamic content like timers/ads).
# TICKET_WATCH_SELECTOR=

# Minutes between checks in --watch mode (minimum 2 is enforced).
# CHECK_INTERVAL_MIN=5

# --- Notifications (optional) ----------------------------------------------
# Telegram: create a bot via @BotFather, then get your chat id.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Generic webhook (Discord/Slack/etc.). Receives a JSON body with {text, content}.
# TICKET_WATCH_WEBHOOK=
