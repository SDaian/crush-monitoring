{
  "name": "crush-monitoring",
  "version": "1.0.0",
  "description": "Synthetic monitoring for Crush Software: API schema checks + UI journeys via Playwright.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "playwright test",
    "test:api": "playwright test --project=api",
    "test:ui": "playwright test --project=ui",
    "test:headed": "playwright test --project=ui --headed",
    "report": "playwright show-report reports/html",
    "check:connectivity": "node scripts/check-connectivity.js",
    "watch:tickets": "node scripts/ticket-watch.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  }
}
